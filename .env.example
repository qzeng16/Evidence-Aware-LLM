# Verifier execution mode:
# - rule_only: use the implemented rule-based verifier
# - llm_only: reserved for the future LLM verifier
# - hybrid: reserved for combined rule and LLM verification
VERIFIER_MODE=rule_only

# OpenAI provider configuration
# Leave the example key empty. Never commit a real API key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=2
